# ============================================================================
# CasaGiusta — Environment Variables
# ============================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

# AI Provider (Anthropic primary)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20260514

# AI Provider (OpenAI fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1

# AI Provider (Privacy mode - local Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.3:70b

# Embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Google Cloud Vision (OCR)
GOOGLE_CLOUD_VISION_CREDENTIALS=base64-encoded-credentials

# Resend (Email)
RESEND_API_KEY=re_...
RESEND_FROM=noreply@casagiusta.it

# OneSignal (Push Notifications)
ONESIGNAL_APP_ID=...
ONESIGNAL_API_KEY=...

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (Error Tracking)
SENTRY_DSN=https://...
SENTRY_AUTH_TOKEN=...

# RevenueCat (In-app purchases)
REVENUECAT_API_KEY=appl_...
REVENUECAT_WEBHOOK_SECRET=...

# Stripe (Web payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Cloudflare R2 (Backup storage)
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=casagiusta-backup
R2_ENDPOINT=https://...
R2_PUBLIC_URL=https://...

# App
APP_ENV=development
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
