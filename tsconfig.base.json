{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@casagiusta/shared": ["./packages/shared/src"],
      "@casagiusta/shared/*": ["./packages/shared/src/*"],
      "@casagiusta/ai": ["./packages/ai/src"],
      "@casagiusta/ai/*": ["./packages/ai/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
